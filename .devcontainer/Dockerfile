# -- AWS CLI
ARG AWSCLI=false
# renovate: datasource=github-tags depName=aws/aws-cli
ARG AWS_VER=2.35.17

RUN --mount=type=bind,source=.devcontainer/awscli.pub,target=/tmp/awscli.pub \
    if [ "$AWSCLI" = "true" ]; then \
    ARCH="$(uname -m)" && \
    curl -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-${ARCH}-$AWS_VER.zip" \
    -o /tmp/awscliv2.zip && \
    curl -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-${ARCH}-$AWS_VER.zip.sig" \
    -o /tmp/awscliv2.sig && \
    gpg --import /tmp/awscli.pub && \
    ACTUAL=$(gpg --fingerprint A6310ACC4672475C 2>/dev/null \
    | grep -A1 "pub" | tail -1 | tr -d ' ') && \
    EXPECTED="FB5DB77FD5C118B80511ADA8A6310ACC4672475C" && \
    [ "$ACTUAL" = "$EXPECTED" ] && \
    echo "${EXPECTED}:6:" | gpg --import-ownertrust && \
    gpg --verify /tmp/awscliv2.sig /tmp/awscliv2.zip && \
    unzip -q /tmp/awscliv2.zip -d /tmp && \
    /tmp/aws/install && \
    rm -rf /tmp/awscliv2.zip /tmp/awscliv2.sig /tmp/aws; \
    fi
# End AWS CLI

# -- GitHub CLI
ARG GHCLI=false
# renovate: datasource=github-releases depName=cli/cli extractVersion=^v(?<version>.*)$
ARG GH_VER=2.95.0

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    if [ "$GHCLI" = "true" ]; then \
    ARCH="$(dpkg --print-architecture)" && \
    DEB="gh_${GH_VER}_linux_${ARCH}.deb" && \
    BASE="https://github.com/cli/cli/releases/download/v${GH_VER}" && \
    curl -fsSL "${BASE}/${DEB}" -o "/tmp/${DEB}" && \
    curl -fsSL "${BASE}/gh_${GH_VER}_checksums.txt" -o /tmp/gh_checksums.txt && \
    ( cd /tmp && grep " ${DEB}\$" gh_checksums.txt > gh.sha && sha256sum -c gh.sha ) && \
    apt-get update && \
    apt-get install -y --no-install-recommends "/tmp/${DEB}" && \
    rm -f "/tmp/${DEB}" /tmp/gh_checksums.txt /tmp/gh.sha && \
    rm -rf /var/lib/apt/lists/*; \
    fi
# -- End GitHub CLI