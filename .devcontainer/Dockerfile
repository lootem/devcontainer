# -- Persistent environment variables
ENV PATH="/usr/local/go/bin:${PATH}" \
    GOROOT="/usr/local/go" \
    COREPACK_ENABLE_DOWNLOAD_PROMPT=0 \
    DISABLE_AUTOUPDATER=1

# -- Base dependencies
RUN rm -f /etc/apt/apt.conf.d/docker-clean
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    apt-get update && apt-get upgrade -y && \
    apt-get install -y --no-install-recommends \
    bind9-dnsutils whois iputils-ping \
    && update-ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Use bash as the default shell
RUN ln -sf /bin/bash /bin/sh

# -- Claude Code
ARG CLAUDECODE=true
# renovate: datasource=npm depName=@anthropic-ai/claude-code
ARG CLAUDE_VER=2.1.205
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    if [ "$CLAUDECODE" = "true" ]; then \
    install -d -m 0755 /etc/apt/keyrings && \
    curl -fsSL https://downloads.claude.ai/keys/claude-code.asc \
    -o /etc/apt/keyrings/claude-code.asc && \
    ACTUAL=$(gpg --show-keys --fingerprint /etc/apt/keyrings/claude-code.asc 2>/dev/null \
    | grep -A1 "pub" | tail -1 | tr -d ' ') && \
    EXPECTED="31DDDE24DDFAB679F42D7BD2BAA929FF1A7ECACE" && \
    [ "$ACTUAL" = "$EXPECTED" ] && \
    echo "deb [signed-by=/etc/apt/keyrings/claude-code.asc] \
    https://downloads.claude.ai/claude-code/apt/stable stable main" \
    | tee /etc/apt/sources.list.d/claude-code.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends claude-code && \
    rm -rf /var/lib/apt/lists/*; \
    fi
USER vscode
RUN if [ "$CLAUDECODE" = "true" ]; then \
    /usr/bin/claude install $CLAUDE_VER; \
    fi
USER root
# -- End Claude Code

# -- Go
ARG GOLANG=false
# renovate: datasource=golang-version depName=go
ARG GO_VER=1.26.5
# renovate: datasource=go depName=golang.org/x/tools/gopls
ARG GOPLS_VER=0.23.0
